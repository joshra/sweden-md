---
import { withBase } from "../utils/paths";

interface NavItem {
  href: string;
  label: string;
}

interface Props {
  title: string;
  description?: string;
  lang?: string;
  navItems?: NavItem[];
}

const {
  title,
  description = "An AI-native open knowledge base about Sweden.",
  lang = "zh-TW",
  navItems
} = Astro.props;

const isEnglish = lang === "en";
const baseNav = isEnglish
  ? [
      { href: "/en", label: "Home" },
      { href: "/en/graph", label: "Graph" },
      { href: "/en/map", label: "Map" },
      { href: "/en/resources", label: "Resources" },
      { href: "/en/about", label: "About" }
    ]
  : [
      { href: "/", label: "首頁" },
      { href: "/graph", label: "圖譜" },
      { href: "/map", label: "地圖" },
      { href: "/resources", label: "資源" },
      { href: "/about", label: "關於" }
    ];
const activeNav = navItems || baseNav;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=IBM+Plex+Sans:wght@400;500;600&family=Noto+Serif+TC:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #f4efe4;
        --bg-strong: #ebe1d1;
        --surface: rgba(255, 251, 244, 0.84);
        --surface-strong: rgba(255, 247, 237, 0.96);
        --ink: #1f2b22;
        --muted: #5f685f;
        --accent: #c1631d;
        --accent-soft: rgba(193, 99, 29, 0.12);
        --forest: #2e5741;
        --line: rgba(46, 87, 65, 0.16);
        --shadow: 0 24px 80px rgba(31, 43, 34, 0.12);
        --radius-lg: 30px;
        --radius-md: 22px;
        --sans: "IBM Plex Sans", "Noto Sans TC", sans-serif;
        --serif: "Fraunces", "Noto Serif TC", serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--ink);
        font-family: var(--sans);
        background:
          radial-gradient(circle at top, rgba(193, 99, 29, 0.16), transparent 24%),
          radial-gradient(circle at 85% 10%, rgba(46, 87, 65, 0.16), transparent 20%),
          linear-gradient(180deg, var(--bg-strong) 0%, var(--bg) 26%, #f7f3eb 100%);
        min-height: 100vh;
      }

      :global(a) {
        color: inherit;
      }

      img {
        max-width: 100%;
      }

      .shell {
        width: min(1180px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 26px 0 72px;
      }

      .topbar {
        position: sticky;
        top: 14px;
        z-index: 20;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 30px;
        padding: 14px 18px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 249, 241, 0.82);
        box-shadow: var(--shadow);
        backdrop-filter: blur(18px);
      }

      .brand-wrap {
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .brand {
        font-family: var(--serif);
        font-size: clamp(1.35rem, 1.8vw, 1.8rem);
        font-weight: 700;
        text-decoration: none;
        letter-spacing: 0.01em;
      }

      .brand-note {
        color: var(--muted);
        font-size: 0.88rem;
      }

      nav {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      nav a {
        padding: 9px 14px;
        border-radius: 999px;
        color: var(--muted);
        text-decoration: none;
        transition:
          background-color 180ms ease,
          color 180ms ease,
          transform 180ms ease;
      }

      nav a:hover,
      nav a:focus-visible {
        background: var(--accent-soft);
        color: var(--ink);
        transform: translateY(-1px);
      }

      .lang-switch {
        border-left: 1px solid var(--line);
        padding-left: 10px;
      }

      main {
        display: grid;
        gap: 22px;
      }

      .card {
        position: relative;
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: var(--radius-lg);
        background: var(--surface);
        box-shadow: var(--shadow);
        backdrop-filter: blur(18px);
      }

      .card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.36), transparent 45%);
        pointer-events: none;
      }

      .card-inner {
        position: relative;
        padding: 30px;
      }

      .eyebrow {
        margin: 0 0 10px;
        color: var(--forest);
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      h1,
      h2,
      h3 {
        margin: 0;
        font-family: var(--serif);
        font-weight: 700;
        line-height: 1.05;
        text-wrap: balance;
      }

      p {
        line-height: 1.75;
      }

      .button-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .button {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 18px;
        border-radius: 999px;
        border: 1px solid transparent;
        background: var(--forest);
        color: #fffaf4;
        text-decoration: none;
        font-weight: 600;
        transition:
          transform 180ms ease,
          opacity 180ms ease,
          background-color 180ms ease;
      }

      .button:hover,
      .button:focus-visible {
        transform: translateY(-2px);
        opacity: 0.94;
      }

      .button.secondary {
        background: transparent;
        color: var(--ink);
        border-color: var(--line);
      }

      footer {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        margin-top: 28px;
        padding: 0 6px;
        color: var(--muted);
        font-size: 0.92rem;
      }

      @media (max-width: 900px) {
        .topbar {
          border-radius: 28px;
          padding: 16px;
        }

        .brand-wrap,
        footer {
          flex-direction: column;
          align-items: flex-start;
        }

        nav {
          justify-content: flex-start;
        }
      }

      @media (max-width: 720px) {
        .shell {
          width: min(100vw - 18px, 1180px);
          padding-top: 14px;
        }

        .topbar {
          position: static;
          gap: 12px;
          border-radius: 24px;
        }

        .card-inner {
          padding: 22px;
        }

        .lang-switch {
          border-left: 0;
          padding-left: 0;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <div class="brand-wrap">
          <a class="brand" href={withBase(isEnglish ? "/en" : "/")}>Sweden.md</a>
          <span class="brand-note">
            {isEnglish ? "Curated knowledge about Sweden" : "用策展方式理解瑞典"}
          </span>
        </div>
        <nav>
          {activeNav.map((item) => (
            <a href={withBase(item.href)}>{item.label}</a>
          ))}
          <a class="lang-switch" href={withBase(isEnglish ? "/" : "/en")}>{isEnglish ? "中文" : "EN"}</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer>
        <span>
          {isEnglish
            ? "Structured in Markdown, projected into a browsable editorial site."
            : "先寫 Markdown，再投影成可瀏覽的策展網站。"}
        </span>
        <span>{isEnglish ? "Single source of truth: knowledge/" : "單一真實來源：knowledge/"}</span>
      </footer>
    </div>
  </body>
</html>
