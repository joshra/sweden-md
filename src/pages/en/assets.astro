---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Assets | Sweden.md" description="Brand and showcase asset entry point for Sweden.md." lang="en">
  <section class="card">
    <div class="card-inner hero">
      <p class="eyebrow">Assets</p>
      <h1>A place for future screenshots, media kit material, and reusable site assets.</h1>
      <p class="lede">This keeps the frontend information architecture ready for shareable visuals and licensed imagery later on.</p>
    </div>
  </section>
</Layout>

<style>
  .hero { display:grid; gap:18px; }
  h1 { font-size: clamp(2.6rem, 5vw, 4.6rem); margin:0; }
  .lede { color: var(--muted); }
</style>
