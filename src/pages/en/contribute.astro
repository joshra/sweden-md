---
import Layout from "../../layouts/Layout.astro";

const paths = [
  {
    title: "Write in Markdown",
    description: "The most direct path. Edit `knowledge/` and follow the editorial template and standards.",
    action: "Edit knowledge/"
  },
  {
    title: "Propose a topic first",
    description: "If the scope is still fuzzy, start with a topic proposal, category, and likely source direction.",
    action: "Pitch a topic"
  },
  {
    title: "Improve frontend and UX",
    description: "Navigation, visuals, SEO, interactive graph work, and site behavior are all valid contributions.",
    action: "Frontend work"
  }
];
---

<Layout title="Contribute | Sweden.md" description="Contribute to Sweden.md through content, frontend work, and resource curation." lang="en">
  <section class="card">
    <div class="card-inner hero">
      <div>
        <p class="eyebrow">Contribute</p>
        <h1>This site grows through clear participation paths, not just more articles.</h1>
        <p class="lede">Following `taiwan.md`, Sweden.md should make it obvious how new contributors can enter, whether through essays, source curation, or frontend work.</p>
      </div>
      <div class="button-row">
        <a class="button" href="/en/about">Read the editorial method</a>
        <a class="button secondary" href="https://github.com/frank890417/taiwan-md" target="_blank" rel="noreferrer">See taiwan-md</a>
      </div>
    </div>
  </section>

  <section class="grid">
    {paths.map((path) => (
      <article class="card">
        <div class="card-inner">
          <p class="eyebrow">{path.action}</p>
          <h2>{path.title}</h2>
          <p>{path.description}</p>
        </div>
      </article>
    ))}
  </section>
</Layout>

<style>
  .hero,
  .grid {
    display: grid;
    gap: 18px;
  }
  .hero {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
  }
  h1 {
    font-size: clamp(2.6rem, 5vw, 4.6rem);
    margin-bottom: 12px;
  }
  .lede,
  .grid p {
    color: var(--muted);
  }
  .grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .grid h2,
  .grid p {
    margin: 0;
  }
  .grid h2 {
    margin-bottom: 10px;
  }
  @media (max-width: 980px) {
    .hero,
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
