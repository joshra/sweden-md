---
import Layout from "../../layouts/Layout.astro";
import { getAllArticles, getCategories } from "../../utils/content";

const categories = getCategories("en").filter((category) => !["about", "resources"].includes(category.slug));
const articles = getAllArticles("en").filter((article) => !article.isHub && article.category !== "resources" && article.category !== "about");

const centerX = 620;
const centerY = 420;
const categoryRadius = 250;

const categoryNodes = categories.map((category, index) => {
  const angle = (Math.PI * 2 * index) / categories.length - Math.PI / 2;
  return {
    id: category.slug,
    label: `${category.emoji} ${category.title}`,
    x: centerX + Math.cos(angle) * categoryRadius,
    y: centerY + Math.sin(angle) * categoryRadius,
    color: {
      history: "#9e3d2d",
      geography: "#4d6c3d",
      culture: "#8c5b6c",
      food: "#bf6a2b",
      art: "#8d4f96",
      music: "#496b96",
      technology: "#2f6682",
      nature: "#417246",
      people: "#8b6a38",
      society: "#5f5f8b",
      economy: "#98623d",
      lifestyle: "#657f42"
    }[category.slug] || "#5f685f",
    href: category.href
  };
});

const articleNodes = categoryNodes.flatMap((categoryNode) => {
  const related = articles.filter((article) => article.category === categoryNode.id).slice(0, 8);
  return related.map((article, index) => {
    const spread = related.length === 1 ? 0 : (index / (related.length - 1) - 0.5) * 1.4;
    const angle = Math.atan2(categoryNode.y - centerY, categoryNode.x - centerX) + spread;
    return {
      id: `${article.category}/${article.slug}`,
      label: article.title,
      x: categoryNode.x + Math.cos(angle) * 130,
      y: categoryNode.y + Math.sin(angle) * 130,
      color: categoryNode.color,
      category: article.category,
      href: article.href
    };
  });
});
---

<Layout title="Knowledge Graph | Sweden.md" description="Explore article connections, category clusters, and cross-topic paths in Sweden.md." lang="en" pageType="graph" accent="#588cb9" accentSoft="rgba(88, 140, 185, 0.16)">
  <section class="card graph-shell">
    <div class="card-inner graph-header">
      <div>
        <p class="eyebrow">Knowledge graph</p>
        <h1>No article stands alone.</h1>
        <p class="lede">This is Sweden.md's content topology. Search nodes, inspect clusters, and jump directly into essays.</p>
      </div>
      <div class="controls">
        <input id="graph-search" type="text" placeholder="Search categories or essays..." />
        <p id="graph-count">Showing all nodes</p>
      </div>
    </div>
    <div class="graph-frame">
      <svg id="graph-svg" viewBox="0 0 1240 840" aria-label="Sweden knowledge graph">
        <circle cx={centerX} cy={centerY} r="78" fill="#1f2b22" />
        <text x={centerX} y={centerY - 10} text-anchor="middle" fill="#fffaf4" font-size="28" font-family="Fraunces, serif">Sweden</text>
        <text x={centerX} y={centerY + 22} text-anchor="middle" fill="#fffaf4" font-size="16" font-family="IBM Plex Sans, sans-serif">Knowledge</text>

        {categoryNodes.map((category) => (
          <>
            <line x1={centerX} y1={centerY} x2={category.x} y2={category.y} stroke={category.color} stroke-opacity="0.35" stroke-width="3" />
            <a href={category.href} class="graph-node category-node" data-label={category.label.toLowerCase()}>
              <circle cx={category.x} cy={category.y} r="18" fill={category.color} />
              <text x={category.x} y={category.y + 40} text-anchor="middle">{category.label}</text>
            </a>
          </>
        ))}

        {articleNodes.map((article) => {
          const category = categoryNodes.find((node) => node.id === article.category);
          return (
            <>
              <line x1={category.x} y1={category.y} x2={article.x} y2={article.y} stroke={article.color} stroke-opacity="0.18" />
              <a href={article.href} class="graph-node article-node" data-label={article.label.toLowerCase()}>
                <circle cx={article.x} cy={article.y} r="8" fill={article.color} />
                <text x={article.x} y={article.y + 22} text-anchor="middle">{article.label}</text>
              </a>
            </>
          );
        })}
      </svg>
    </div>
  </section>
</Layout>

<script>
  const input = document.getElementById("graph-search");
  const count = document.getElementById("graph-count");
  const nodes = [...document.querySelectorAll(".graph-node")];
  input.addEventListener("input", () => {
    const query = input.value.trim().toLowerCase();
    let visible = 0;
    nodes.forEach((node) => {
      const match = !query || node.dataset.label.includes(query);
      node.style.opacity = match ? "1" : "0.12";
      if (match) visible += 1;
    });
    count.textContent = query ? `${visible} results` : "Showing all nodes";
  });
</script>

<style>
  .graph-shell {
    min-height: calc(100vh - 180px);
  }
  .graph-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 18px;
    align-items: end;
    border-bottom: 1px solid var(--line);
  }
  h1 {
    font-size: clamp(2.6rem, 5vw, 4.6rem);
    margin-bottom: 12px;
  }
  .lede,
  #graph-count {
    color: var(--muted);
  }
  .controls {
    display: grid;
    gap: 10px;
  }
  #graph-search {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--surface-strong);
    font: inherit;
    color: var(--ink);
  }
  .graph-frame {
    overflow: auto;
  }
  #graph-svg {
    width: 100%;
    min-height: 840px;
    display: block;
  }
  .graph-node {
    cursor: pointer;
    transition: opacity 180ms ease;
  }
  .graph-node :global(text) {
    fill: #1f2b22;
    font-family: "IBM Plex Sans", sans-serif;
    font-size: 11px;
  }
  .category-node :global(text) {
    font-family: "Fraunces", serif;
    font-size: 14px;
  }
  @media (max-width: 900px) {
    .graph-header {
      grid-template-columns: 1fr;
    }
  }
</style>
