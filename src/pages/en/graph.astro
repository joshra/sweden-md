---
import Layout from "../../layouts/Layout.astro";
import KnowledgeGraph from "../../components/KnowledgeGraph.astro";

const initialQuery = Astro.url.searchParams.get("q")?.trim() || "";
---

<Layout title="Knowledge Graph | Sweden.md" description="Explore article connections, category clusters, and cross-topic paths in Sweden.md." lang="en" pageType="graph" accent="#588cb9" accentSoft="rgba(88, 140, 185, 0.16)">
  <KnowledgeGraph locale="en" initialQuery={initialQuery} />
</Layout>
