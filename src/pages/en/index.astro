---
import Layout from "../../layouts/Layout.astro";
import { getAllArticles, getCategories, getFeaturedArticles, getLatestArticles, getSiteMetrics } from "../../utils/content";
import { withBase } from "../../utils/paths";
import { getCategoryConfig } from "../../utils/categoryConfig";

const categories = getCategories("en");
const primaryCategories = categories.filter((category) => !["about", "resources"].includes(category.slug));
const featuredArticles = getFeaturedArticles("en");
const latestArticles = getLatestArticles("en", 4);
const allArticles = getAllArticles("en").filter((article) => !article.isHub);
const metrics = getSiteMetrics("en");
const prioritizedCategorySlugs = ["culture", "food", "lifestyle", "history"];

const searchIndex = allArticles.map((article) => ({
  title: article.title,
  href: article.href,
  description: article.description || article.excerpt,
  category: categories.find((category) => category.slug === article.category)?.title || article.category,
  readingMinutes: article.readingMinutes
}));

const readingPaths = [
  {
    title: "Cultural entry points",
    text: "Begin with fika, the home table, seasonal rituals, and domestic design. Culture is the fastest way into how Sweden feels in practice."
  },
  {
    title: "Everyday rhythms",
    text: "Read work boundaries, parental leave, domestic space, and public aesthetics together to understand how time and social life are arranged."
  },
  {
    title: "Institutions and transition",
    text: "Only after culture has done its work should you move into welfare institutions, cities, technology, and the larger national frame."
  }
];

const homeTopics = [
  ...featuredArticles.slice(0, 5),
  ...[
    ...primaryCategories.filter((category) => prioritizedCategorySlugs.includes(category.slug)),
    ...primaryCategories.filter((category) => !prioritizedCategorySlugs.includes(category.slug))
  ]
    .filter((category) => !featuredArticles.some((article) => article.category === category.slug))
    .slice(0, 4)
    .map((category) => ({
      href: category.href,
      title: category.title,
      description: category.description,
      category: category.title,
      readingMinutes: category.articleCount,
      isCategory: true
    }))
];

const utilityLinks = [
  { title: "Search graph", href: withBase("/en/graph"), note: "Find articles and categories through relationships." },
  { title: "Map view", href: withBase("/en/map"), note: "Browse through place and regional structure." },
  { title: "Sources and resources", href: withBase("/en/resources"), note: "Official sites, data portals, and research entry points." },
  { title: "About Sweden.md", href: withBase("/en/about"), note: "Editorial framing, method, and writing standards." }
];
---

<Layout
  title="Sweden.md English"
  description="A curated front door into Sweden for readers who want more structure than stereotype."
  lang="en"
  pageType="home"
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Sweden.md</p>
      <h1>Read Sweden in a way that feels closer, calmer, and clearer.</h1>
      <p class="lead">
        For readers who want to understand Sweden without being buried under raw information, this is a gentler way in. You begin with fika, the table, seasonal rituals, and everyday rhythm, then move naturally into cities, institutions, history, and contemporary change.
      </p>

      <div class="hero-metrics">
        <article>
          <strong>{metrics.articleCount}+</strong>
          <span>Topic essays</span>
        </article>
        <article>
          <strong>{metrics.categoryCount}</strong>
          <span>Core categories</span>
        </article>
        <article>
          <strong>{featuredArticles.length}</strong>
          <span>Starter routes</span>
        </article>
      </div>
    </div>

    <aside class="hero-panel">
      <p class="eyebrow">From Taiwan to Sweden</p>
      <h2>What readers get here</h2>
      <p>
        Not a cold taxonomy and not an information system that asks you to decode itself first. It is built more like a reading room: calm to enter, easy to follow, and structured so depth arrives through good essays rather than friction.
      </p>
      <ul>
        <li>Start from strong human entry points instead of institutional jargon.</li>
        <li>Let the essays carry the structure so reading still feels relaxed.</li>
        <li>Keep the depth and sourcing, but make the experience feel inviting first.</li>
      </ul>
      <div class="north-star">
        <span>N</span>
        <span>S</span>
        <span>Forests, energy, and resource landscapes</span>
        <span>Population, cities, and institutional cores</span>
      </div>
    </aside>
  </section>

  <section class="section-heading">
    <p class="eyebrow">Reading Path</p>
    <h2>Start with culture and daily life, then widen into institutions, cities, and scale.</h2>
  </section>

  <section class="feature-grid">
    {readingPaths.map((item) => (
      <article>
        <h2>{item.title}</h2>
        <p>{item.text}</p>
      </article>
    ))}
  </section>

  <section class="section-heading">
    <p class="eyebrow">Starter Topics</p>
    <h2>Culture-led starters make Sweden easier to enter than a cold category list.</h2>
  </section>

  <section class="topic-grid">
    {homeTopics.map((item, index) => (
      <article class="topic-card">
        <p class="topic-number">{item.isCategory ? "Category" : `Start ${index + 1}`}</p>
        <h2><a href={item.href}>{item.title}</a></h2>
        <p>{item.description}</p>
        <div class="pill-row">
          <span class="pill">{item.isCategory ? item.category : categories.find((category) => category.slug === item.category)?.title}</span>
          <span class="pill">{item.isCategory ? `${item.readingMinutes} articles` : `${item.readingMinutes} min`}</span>
        </div>
      </article>
    ))}
  </section>

  <section class="section-heading split-heading">
    <div>
      <p class="eyebrow">Recent Updates</p>
      <h2>Recently added and expanded</h2>
    </div>
    <a class="inline-link" href={withBase("/en/changelog")}>See all updates →</a>
  </section>

  <section class="latest-grid">
    {latestArticles.map((article) => (
      <article class="latest-card">
        <p class="topic-number">Latest</p>
        <h2><a href={article.href}>{article.title}</a></h2>
        <p>{article.description || article.excerpt}</p>
        <div class="pill-row">
          <span class="pill">{categories.find((category) => category.slug === article.category)?.title}</span>
          <span class="pill">{article.updatedAt.toLocaleDateString("en-US")}</span>
        </div>
      </article>
    ))}
  </section>

  <section class="section-heading">
    <p class="eyebrow">All Categories</p>
    <h2>Every category is a good place to start.</h2>
  </section>

  <section class="category-chips">
    {primaryCategories.map((cat) => {
      const cfg = getCategoryConfig(cat.slug);
      return (
        <a
          class="cat-chip"
          href={cat.href}
          style={`--chip-accent:${cfg?.accent ?? '#0f766e'};--chip-soft:${cfg?.accentSoft ?? 'rgba(15,118,110,0.12)'}`}
        >
          <span class="cat-chip-emoji">{cat.emoji}</span>
          <span class="cat-chip-name">{cat.title}</span>
          <span class="cat-chip-count">{cat.articleCount} articles</span>
        </a>
      );
    })}
  </section>

  <section class="utility-strip">
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">Tools</p>
        <h2>Search and site utilities</h2>
      </div>
    </div>

    <div class="utility-grid">
      {utilityLinks.map((item) => (
        <a class="utility-card" href={item.href}>
          <h3>{item.title}</h3>
          <p>{item.note}</p>
        </a>
      ))}
    </div>

    <form id="search" class="search-panel" action={withBase("/en/graph")}>
      <label class="eyebrow" for="home-search">Search</label>
      <input id="home-search" type="search" name="q" placeholder="For example: welfare, Gothenburg, fika, Spotify" autocomplete="off" />
      <div id="search-results" class="search-results" aria-live="polite">
        {searchIndex.slice(0, 6).map((article) => (
          <a class="search-result" href={article.href}>
            <strong>{article.title}</strong>
            <span>{article.category} · {article.readingMinutes} min · {article.description}</span>
          </a>
        ))}
      </div>
    </form>
  </section>
</Layout>

<script define:vars={{ searchIndex }}>
  const input = document.getElementById("home-search");
  const results = document.getElementById("search-results");

  if (input instanceof HTMLInputElement && results instanceof HTMLElement) {
    const renderResults = (items) => {
      results.innerHTML = items
        .map(
          (article) => `
            <a class="search-result" href="${article.href}">
              <strong>${article.title}</strong>
              <span>${article.category} · ${article.readingMinutes} min · ${article.description}</span>
            </a>
          `
        )
        .join("");
    };

    const defaultResults = searchIndex.slice(0, 6);
    renderResults(defaultResults);

    input.addEventListener("input", () => {
      const query = input.value.trim().toLowerCase();
      if (!query) {
        renderResults(defaultResults);
        return;
      }

      const filtered = searchIndex
        .filter((article) =>
          [article.title, article.description, article.category].some((field) =>
            field.toLowerCase().includes(query)
          )
        )
        .slice(0, 6);

      renderResults(
        filtered.length
          ? filtered
          : [
              {
                href: `${withBase("/en/graph")}?q=${encodeURIComponent(query)}`,
                title: `Search "${query}" in the graph view`,
                category: "Keep searching",
                readingMinutes: "Graph",
                description: "Continue into the full article and category network."
              }
            ]
      );
    });
  }
</script>

<style>
  .hero,
  .feature-grid,
  .topic-grid,
  .latest-grid,
  .utility-grid {
    display: grid;
    gap: 20px;
  }

  .hero,
  .feature-grid article,
  .topic-card,
  .latest-card,
  .utility-card,
  .search-panel {
    backdrop-filter: blur(12px);
    background: rgba(255, 251, 244, 0.9);
    border: 1px solid rgba(25, 33, 38, 0.12);
    box-shadow: 0 24px 60px rgba(25, 33, 38, 0.1);
  }

  .hero {
    grid-template-columns: 1.3fr 0.9fr;
    gap: 24px;
    padding: 32px;
    border-radius: 32px;
    position: relative;
    overflow: hidden;
  }

  .hero::after {
    content: "";
    position: absolute;
    width: 340px;
    height: 340px;
    right: -60px;
    top: -80px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(15, 118, 110, 0.18), transparent 68%);
  }

  .hero h1 {
    font-size: clamp(3rem, 5vw, 5.2rem);
    line-height: 1.05;
    margin: 0 0 14px;
    max-width: 11ch;
  }

  .eyebrow,
  .topic-number {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    color: #0f766e;
    margin: 0 0 10px;
  }

  .topic-number {
    display: inline-block;
    padding: 4px 8px;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.1);
  }

  .lead,
  .hero-panel p,
  .hero-panel li,
  .feature-grid p,
  .topic-card p,
  .latest-card p,
  .utility-card p,
  .search-result span {
    color: var(--muted);
  }

  .lead {
    max-width: 60ch;
    font-size: 1.08rem;
  }

  .hero-panel,
  .search-panel {
    padding: 22px;
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(15, 118, 110, 0.12), rgba(217, 119, 6, 0.06)),
      linear-gradient(135deg, rgba(255, 255, 255, 0.55), rgba(255, 255, 255, 0.2));
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 24px;
    max-width: 640px;
  }

  .hero-metrics article {
    padding: 14px 16px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(25, 33, 38, 0.08);
  }

  .hero-metrics strong {
    display: block;
    font-size: 1.6rem;
    color: #0f766e;
  }

  .north-star {
    margin-top: 18px;
    display: grid;
    grid-template-columns: 32px 32px 1fr 1fr;
    gap: 10px;
    align-items: center;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .north-star span:nth-child(1),
  .north-star span:nth-child(2) {
    display: inline-grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(25, 33, 38, 0.12);
    color: #0f766e;
    background: rgba(255, 255, 255, 0.65);
  }

  .section-heading {
    margin-top: 10px;
    padding-inline: 4px;
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.5rem, 2vw, 2.2rem);
    max-width: 24ch;
  }

  .split-heading {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: end;
  }

  .feature-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .feature-grid article,
  .topic-card,
  .latest-card,
  .utility-card {
    padding: 24px;
    border-radius: 24px;
    position: relative;
    overflow: hidden;
  }

  .feature-grid article::after,
  .topic-card::after,
  .latest-card::after {
    content: "";
    position: absolute;
    inset: auto -24px -40px auto;
    width: 110px;
    height: 110px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(15, 118, 110, 0.12), transparent 70%);
  }

  .topic-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .latest-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .utility-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-bottom: 20px;
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.08);
    color: #0f766e;
    font-size: 0.88rem;
  }

  .inline-link,
  .topic-card a,
  .latest-card a,
  .utility-card {
    text-decoration: none;
  }

  .search-panel input {
    width: 100%;
    padding: 14px 16px;
    border-radius: 14px;
    border: 1px solid rgba(25, 33, 38, 0.12);
    background: rgba(255, 255, 255, 0.7);
    color: var(--ink);
    font: inherit;
  }

  .search-results {
    display: grid;
    gap: 10px;
    margin-top: 14px;
  }

  .search-result {
    display: grid;
    gap: 4px;
    padding: 12px 14px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(25, 33, 38, 0.08);
    text-decoration: none;
  }

  @media (max-width: 1100px) {
    .hero,
    .feature-grid,
    .topic-grid,
    .latest-grid,
    .utility-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .split-heading {
      display: grid;
    }
  }

  .category-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .cat-chip {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 10px 16px;
    border-radius: 999px;
    border: 1px solid var(--chip-soft, rgba(15, 118, 110, 0.14));
    background: var(--chip-soft, rgba(15, 118, 110, 0.08));
    color: var(--chip-accent, #0f766e);
    font-size: 0.9rem;
    text-decoration: none;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
    backdrop-filter: blur(8px);
  }

  .cat-chip:hover,
  .cat-chip:focus-visible {
    transform: translateY(-2px);
    border-color: var(--chip-accent, #0f766e);
    background: rgba(255, 255, 255, 0.72);
  }

  .cat-chip-emoji { font-size: 1.05rem; line-height: 1; }
  .cat-chip-name  { font-weight: 600; }
  .cat-chip-count { font-size: 0.78rem; opacity: 0.72; }

  @media (max-width: 780px) {
    .hero,
    .feature-grid,
    .topic-grid,
    .latest-grid,
    .utility-grid,
    .hero-metrics {
      grid-template-columns: 1fr;
    }

    .north-star {
      grid-template-columns: 32px 32px 1fr;
    }

    .hero {
      padding: 24px;
    }
  }
</style>
