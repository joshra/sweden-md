---
import Layout from "../../layouts/Layout.astro";
import { getAllArticles, getCategories, getFeaturedArticles, getLatestArticles, getSiteMetrics } from "../../utils/content";
import { withBase } from "../../utils/paths";

const categories = getCategories("en");
const primaryCategories = categories.filter((category) => !["about", "resources"].includes(category.slug));
const featuredArticles = getFeaturedArticles("en");
const latestArticles = getLatestArticles("en", 6);
const allArticles = getAllArticles("en").filter((article) => !article.isHub);
const metrics = getSiteMetrics("en");

const searchIndex = allArticles.map((article) => ({
  title: article.title,
  href: article.href,
  description: article.description || article.excerpt,
  category: categories.find((category) => category.slug === article.category)?.title || article.category,
  readingMinutes: article.readingMinutes
}));

const trendingTopics = [...primaryCategories].sort((a, b) => b.articleCount - a.articleCount).slice(0, 6);

const featuredSeries = [
  {
    eyebrow: "State and history",
    title: "Start with history, institutions, and geography before Sweden collapses into stereotype.",
    href: withBase("/en/history"),
    note: "Build a working frame through state formation, welfare development, and regional difference."
  },
  {
    eyebrow: "Daily life",
    title: "Enter through fika, family rhythms, and seasonal rituals.",
    href: withBase("/en/culture"),
    note: "A route for readers who want abstract values translated into lived practice."
  },
  {
    eyebrow: "Cities and industry",
    title: "Move from urban nodes into technology, labor, and modern economic life.",
    href: withBase("/en/cities"),
    note: "A contemporary path through Sweden's spatial structure, talent flows, and industrial base."
  }
];

const utilityLinks = [
  { eyebrow: "🗺️ Map", title: "Browse the site through place and spatial clusters.", href: withBase("/en/map") },
  { eyebrow: "📚 Resources", title: "Jump into official sites, data portals, and research sources.", href: withBase("/en/resources") },
  { eyebrow: "ℹ️ About", title: "Read the editorial framing and project method.", href: withBase("/en/about") },
  { eyebrow: "🕒 Changelog", title: "Track newly added and expanded articles.", href: withBase("/en/changelog") },
  { eyebrow: "✋ Contribute", title: "Start here if you want to improve content or frontend structure.", href: withBase("/en/contribute") }
];

const audienceUseCases = [
  "Readers who want a coherent understanding of Sweden rather than a stack of Nordic stereotypes.",
  "People who need a reliable, source-aware entry point for research, teaching, writing, or product context.",
  "Anyone who wants to move from a single topic into the wider institutional, cultural, urban, and economic picture."
];
---

<Layout
  title="Sweden.md English"
  description="A curated entry point into Sweden's history, institutions, culture, and technology."
  lang="en"
  pageType="home"
>
  <section class="card hero cover-panel">
    <div class="card-inner hero-grid">
      <div>
        <p class="eyebrow">Sweden.md | A curated knowledge entry point to Sweden</p>
        <h1>Understand Sweden with more structure and less stereotype.</h1>
        <p class="lede">
          Sweden.md is not a travel notebook or a loose encyclopedia. It organizes Sweden's history, society, culture, cities, and technology into a readable, sourced, editorially framed knowledge base for first-time and returning readers.
        </p>

        <div class="button-row">
          <a class="button" href="#featured">Start reading</a>
          <a class="button secondary" href="#search">Search the site</a>
          <a class="button secondary" href="#latest">Latest updates</a>
        </div>

        <form id="search" class="search-panel" action={withBase("/en/graph")}>
          <label class="search-label" for="home-search">Search essays, categories, cities, or key topics</label>
          <input id="home-search" type="search" name="q" placeholder="For example: welfare, fika, Stockholm, Spotify" autocomplete="off" />
          <div id="search-results" class="search-results" aria-live="polite">
            {searchIndex.slice(0, 6).map((article) => (
              <a class="search-result" href={article.href} data-search-item>
                <span class="search-meta">{article.category} · {article.readingMinutes} min</span>
                <strong>{article.title}</strong>
                <span>{article.description}</span>
              </a>
            ))}
          </div>
        </form>
      </div>

      <div class="hero-side">
        <div class="stat-grid">
          <article>
            <strong>{metrics.articleCount}+</strong>
            <span>Topic essays</span>
          </article>
          <article>
            <strong>{metrics.categoryCount}</strong>
            <span>Core categories</span>
          </article>
          <article>
            <strong>{featuredArticles.length}</strong>
            <span>Starter picks</span>
          </article>
          <article>
            <strong>{latestArticles.length}</strong>
            <span>Recent updates</span>
          </article>
        </div>

        <div class="signal">
          <p class="signal-label">Who this is for</p>
          <ul class="audience-list">
            {audienceUseCases.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="trending" class="split">
    <article class="card">
      <div class="card-inner">
        <div class="section-head compact">
          <div>
            <p class="eyebrow">Trending topics</p>
            <h2>High-density themes</h2>
          </div>
          <p class="section-note">Start where the library is already deepest, so one article can lead naturally into the next.</p>
        </div>

        <div class="topic-cluster">
          {trendingTopics.map((category) => (
            <a class="topic-chip" href={category.href}>
              <span>{category.emoji} {category.title}</span>
              <strong>{category.articleCount} articles</strong>
            </a>
          ))}
        </div>
      </div>
    </article>

    <article class="card">
      <div class="card-inner">
        <div class="section-head compact">
          <div>
            <p class="eyebrow">Series</p>
            <h2>Editorial entry paths</h2>
          </div>
          <p class="section-note">If you are unsure where to begin, start with a path rather than a random page.</p>
        </div>

        <div class="series-list">
          {featuredSeries.map((series) => (
            <a class="series-card" href={series.href}>
              <p class="eyebrow">{series.eyebrow}</p>
              <h3>{series.title}</h3>
              <p>{series.note}</p>
            </a>
          ))}
        </div>
      </div>
    </article>
  </section>

  <section id="featured" class="card editorial-band">
    <div class="card-inner">
      <div class="section-head">
        <div>
          <p class="eyebrow">Editor's picks</p>
          <h2>Five essays to orient a first visit.</h2>
        </div>
        <p class="section-note">These are not a random sample. They are a deliberate starting sequence for a first visit.</p>
      </div>

      <div class="feature-grid">
        {featuredArticles.map((article, index) => (
          <a class="feature-card" href={article.href}>
            <span class="index">{String(index + 1).padStart(2, "0")}</span>
            <div>
              <p class="feature-meta">{categories.find((category) => category.slug === article.category)?.title}</p>
              <h3>{article.title}</h3>
              <p>{article.description || article.excerpt}</p>
            </div>
            <span class="read-time">{article.readingMinutes} min</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="latest" class="card editorial-band latest-band">
    <div class="card-inner">
      <div class="section-head">
        <div>
          <p class="eyebrow">Latest</p>
          <h2>Recently updated</h2>
        </div>
        <p class="section-note">Track the newest additions and major revisions to see which parts of the knowledge base are expanding now.</p>
      </div>

      <div class="latest-grid">
        {latestArticles.map((article) => (
          <a class="latest-card" href={article.href}>
            <span class="latest-category">{categories.find((category) => category.slug === article.category)?.title}</span>
            <h3>{article.title}</h3>
            <p>{article.description || article.excerpt}</p>
            <span class="latest-meta">{article.updatedAt.toLocaleDateString("en-US")} · {article.readingMinutes} min</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="categories" class="card editorial-band categories-band">
    <div class="card-inner">
      <div class="section-head">
        <div>
          <p class="eyebrow">Explore</p>
          <h2>All category entry points</h2>
        </div>
        <p class="section-note">The full taxonomy stays available for readers who prefer to build their own map of the site.</p>
      </div>

      <div class="category-grid">
        {primaryCategories.map((category) => (
          <a class="category-card" href={category.href}>
            <div class="category-top">
              <span class="emoji">{category.emoji}</span>
              <span class="count">{category.articleCount} articles</span>
            </div>
            <h3>{category.title}</h3>
            <p>{category.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="toolbox">
    <div class="section-head compact">
      <div>
        <p class="eyebrow">Tools and site</p>
        <h2>Utility pages</h2>
      </div>
      <p class="section-note">Important, but intentionally secondary to reading and discovery.</p>
    </div>

    <div class="utility-grid">
      {utilityLinks.map((item) => (
        <a class="card utility-card" href={item.href}>
          <div class="card-inner">
            <p class="eyebrow">{item.eyebrow}</p>
            <h3>{item.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<script define:vars={{ searchIndex }}>
  const input = document.getElementById("home-search");
  const results = document.getElementById("search-results");

  if (input instanceof HTMLInputElement && results instanceof HTMLElement) {
    const renderResults = (items) => {
      results.innerHTML = items
        .map(
          (article) => `
            <a class="search-result" href="${article.href}">
              <span class="search-meta">${article.category} · ${article.readingMinutes} min</span>
              <strong>${article.title}</strong>
              <span>${article.description}</span>
            </a>
          `
        )
        .join("");
    };

    const defaultResults = searchIndex.slice(0, 6);
    renderResults(defaultResults);

    input.addEventListener("input", () => {
      const query = input.value.trim().toLowerCase();

      if (!query) {
        renderResults(defaultResults);
        return;
      }

      const filtered = searchIndex
        .filter((article) =>
          [article.title, article.description, article.category].some((field) =>
            field.toLowerCase().includes(query)
          )
        )
        .slice(0, 6);

      renderResults(
        filtered.length
          ? filtered
          : [
              {
                href: `${withBase("/en/graph")}?q=${encodeURIComponent(query)}`,
                category: "Keep searching",
                title: `No exact match. Search "${query}" in the graph view.`,
                description: "Continue into the full category and article network.",
                readingMinutes: "Graph"
              }
            ]
      );
    });
  }
</script>

<style>
  .hero-grid,
  .split,
  .section-head,
  .utility-grid,
  .latest-grid {
    display: grid;
    gap: 22px;
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.85fr);
    align-items: start;
    min-height: 500px;
  }

  .cover-panel {
    background:
      radial-gradient(circle at 78% 16%, rgba(34, 93, 109, 0.22), transparent 24%),
      radial-gradient(circle at 10% 10%, rgba(191, 106, 43, 0.16), transparent 22%),
      linear-gradient(180deg, rgba(255, 248, 238, 0.98), rgba(247, 239, 228, 0.92));
  }

  h1 {
    font-size: clamp(3rem, 6vw, 5.6rem);
    max-width: 10ch;
    margin-bottom: 18px;
  }

  .lede {
    max-width: 61ch;
    margin: 0 0 26px;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .hero h1 {
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.45);
  }

  .hero-side,
  .series-list,
  .toolbox {
    display: grid;
    gap: 16px;
  }

  .hero-side {
    align-self: stretch;
  }

  .search-panel,
  .signal,
  .stat-grid article,
  .feature-card,
  .category-card,
  .latest-card,
  .series-card,
  .topic-chip,
  .search-result {
    border: 1px solid var(--line);
    border-radius: 22px;
    background: var(--surface-strong);
  }

  .search-panel {
    background:
      linear-gradient(180deg, rgba(255, 254, 250, 0.9), rgba(248, 239, 226, 0.92)),
      repeating-linear-gradient(0deg, transparent 0, transparent 26px, rgba(31, 43, 34, 0.04) 26px, rgba(31, 43, 34, 0.04) 27px);
  }

  .search-panel {
    display: grid;
    gap: 12px;
    margin-top: 24px;
    padding: 18px;
  }

  .search-label,
  .signal-label,
  .search-meta,
  .latest-category,
  .latest-meta,
  .feature-meta,
  .count,
  .section-note,
  .category-card p,
  .series-card p,
  .utility-card p {
    color: var(--muted);
  }

  .search-label,
  .signal-label,
  .latest-category {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  #home-search {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.65);
    color: var(--ink);
    font: inherit;
  }

  #home-search:focus {
    outline: 2px solid rgba(193, 99, 29, 0.24);
    outline-offset: 2px;
  }

  .search-results {
    display: grid;
    gap: 10px;
  }

  .audience-list {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 10px;
    color: var(--muted);
  }

  .search-result {
    display: grid;
    gap: 4px;
    padding: 14px 16px;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .search-result:hover,
  .search-result:focus-visible,
  .feature-card:hover,
  .feature-card:focus-visible,
  .category-card:hover,
  .category-card:focus-visible,
  .latest-card:hover,
  .latest-card:focus-visible,
  .series-card:hover,
  .series-card:focus-visible,
  .topic-chip:hover,
  .topic-chip:focus-visible,
  .utility-card:hover,
  .utility-card:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(193, 99, 29, 0.28);
  }

  .hero-side {
    gap: 18px;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .stat-grid article,
  .signal {
    padding: 18px;
  }

  .stat-grid article {
    position: relative;
    overflow: hidden;
  }

  .stat-grid article::after {
    content: "";
    position: absolute;
    inset: auto -18% -46% 34%;
    height: 120px;
    background: radial-gradient(circle, rgba(191, 106, 43, 0.18), transparent 68%);
    pointer-events: none;
  }

  .signal {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(248, 239, 227, 0.92)),
      repeating-linear-gradient(0deg, transparent 0, transparent 27px, rgba(46, 87, 65, 0.04) 27px, rgba(46, 87, 65, 0.04) 28px);
  }

  .stat-grid strong {
    display: block;
    font-family: var(--serif);
    font-size: 2rem;
  }

  .split {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .section-head {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    margin-bottom: 22px;
  }

  .section-head.compact {
    margin-bottom: 18px;
  }

  .section-head h2 {
    font-size: clamp(2rem, 3vw, 3rem);
  }

  .editorial-band {
    border-radius: 34px;
  }

  .topic-cluster,
  .feature-grid,
  .category-grid,
  .utility-grid,
  .latest-grid {
    display: grid;
    gap: 16px;
  }

  .topic-cluster {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .topic-chip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 18px;
    text-decoration: none;
  }

  .topic-chip strong {
    font-family: var(--serif);
    font-size: 1.15rem;
  }

  .series-card,
  .latest-card,
  .category-card,
  .feature-card {
    text-decoration: none;
  }

  .series-card,
  .latest-card {
    display: grid;
    gap: 8px;
    padding: 20px;
  }

  .feature-grid,
  .latest-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .feature-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 18px;
    padding: 20px;
  }

  .index {
    font-family: var(--serif);
    font-size: 2rem;
    color: var(--accent);
    line-height: 1;
  }

  .read-time {
    align-self: start;
    color: var(--forest);
    font-size: 0.88rem;
    font-weight: 600;
  }

  .category-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .category-card {
    display: grid;
    gap: 12px;
    padding: 20px;
  }

  .category-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .emoji {
    font-size: 1.45rem;
  }

  .utility-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .utility-card {
    text-decoration: none;
  }

  @media (max-width: 980px) {
    .hero-grid,
    .split,
    .feature-grid,
    .category-grid,
    .utility-grid,
    .latest-grid,
    .section-head,
    .topic-cluster {
      grid-template-columns: 1fr;
    }

    h1 {
      max-width: 12ch;
    }
  }
</style>
