---
import Layout from "../../layouts/Layout.astro";
import { getCategories, getFeaturedArticles, getSiteMetrics } from "../../utils/content";
import { withBase } from "../../utils/paths";

const categories = getCategories("en");
const primaryCategories = categories.filter((category) => !["about", "resources"].includes(category.slug));
const utilityCategories = categories.filter((category) => ["about", "resources"].includes(category.slug));
const featuredArticles = getFeaturedArticles("en");
const metrics = getSiteMetrics("en");
const quickLinks = [
  ...utilityCategories.map((category) => ({
    eyebrow: `${category.emoji} ${category.title}`,
    title: category.description,
    href: withBase(category.slug === "about" ? "/en/about" : "/en/resources")
  })),
  { eyebrow: "✋ Contribute", title: "Start here if you want to add content, frontend work, or resource curation.", href: withBase("/en/contribute") },
  { eyebrow: "🕒 Changelog", title: "Follow the latest additions and expansions across the site.", href: withBase("/en/changelog") }
];
---

<Layout
  title="Sweden.md English"
  description="A curated frontend entry point into Sweden's history, institutions, culture, and technology."
  lang="en"
>
  <section class="card hero">
    <div class="card-inner hero-grid">
      <div>
        <p class="eyebrow">Curated knowledge base for Sweden</p>
        <h1>A homepage should guide readers into Sweden, not just describe the repo.</h1>
        <p class="lede">
          The strongest lesson from `taiwan.md` is editorial entry design: give readers a first route through the country, then let them branch into history, institutions, daily life, and technology.
        </p>
        <div class="button-row">
          <a class="button" href="#featured">Start with 5 essays</a>
          <a class="button secondary" href="#categories">Browse categories</a>
          <a class="button secondary" href={withBase("/en/graph")}>Knowledge graph</a>
        </div>
      </div>

      <div class="hero-side">
        <div class="stat-grid">
          <article>
            <strong>{metrics.articleCount}+</strong>
            <span>Articles</span>
          </article>
          <article>
            <strong>{metrics.categoryCount}</strong>
            <span>Core categories</span>
          </article>
          <article>
            <strong>Bilingual</strong>
            <span>Parallel English structure</span>
          </article>
          <article>
            <strong>SSOT</strong>
            <span>Markdown-first architecture</span>
          </article>
        </div>

        <div class="signal">
          <p class="signal-label">Design goal</p>
          <p>
            `taiwan.md` feels alive because it turns editorial structure into navigation. This version applies that lesson to Sweden.md with a stronger hero, featured reading paths, and clearer category movement.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="split">
    <article class="card">
      <div class="card-inner">
        <p class="eyebrow">Three reading layers</p>
        <h2>Orientation first, depth second.</h2>
        <p>
          Readers should be able to enter Sweden through a few clear lenses, then decide where to go deeper. The homepage now foregrounds those lenses instead of exposing internal project structure.
        </p>
      </div>
    </article>

    <article class="card">
      <div class="card-inner">
        <p class="eyebrow">Frontend optimization</p>
        <h2>Make the knowledge network legible.</h2>
        <p>
          The first pass focuses on the same strengths that make `taiwan.md` work: a forceful landing section, a curated starting list, and category cards that carry editorial framing.
        </p>
      </div>
    </article>
  </section>

  <section id="featured" class="card">
    <div class="card-inner">
      <div class="section-head">
        <div>
          <p class="eyebrow">Start here</p>
          <h2>Five pieces to build a first mental map of Sweden.</h2>
        </div>
        <p class="section-note">A compact path across state, society, culture, nature, and technology.</p>
      </div>

      <div class="feature-grid">
        {featuredArticles.map((article, index) => (
          <a class="feature-card" href={article.href}>
            <span class="index">{String(index + 1).padStart(2, "0")}</span>
            <div>
              <p class="feature-meta">{categories.find((category) => category.slug === article.category)?.title}</p>
              <h3>{article.title}</h3>
              <p>{article.description || article.excerpt}</p>
            </div>
            <span class="read-time">{article.readingMinutes} min</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="categories" class="card">
    <div class="card-inner">
      <div class="section-head">
        <div>
          <p class="eyebrow">Explore</p>
          <h2>Move by category, not by accident.</h2>
        </div>
        <p class="section-note">Each category page begins with a framing essay and opens into individual articles.</p>
      </div>

      <div class="category-grid">
        {primaryCategories.map((category) => (
          <a class="category-card" href={category.href}>
            <div class="category-top">
              <span class="emoji">{category.emoji}</span>
              <span class="count">{category.articleCount} articles</span>
            </div>
            <h3>{category.title}</h3>
            <p>{category.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="utility-grid">
    {quickLinks.map((item) => (
      <a class="card utility-card" href={item.href}>
        <div class="card-inner">
          <p class="eyebrow">{item.eyebrow}</p>
          <h2>{item.title}</h2>
        </div>
      </a>
    ))}
  </section>
</Layout>

<style>
  .hero-grid,
  .split,
  .section-head,
  .utility-grid {
    display: grid;
    gap: 22px;
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1.5fr) minmax(320px, 0.9fr);
    align-items: start;
  }

  h1 {
    font-size: clamp(3rem, 6vw, 5.8rem);
    max-width: 10ch;
    margin-bottom: 18px;
  }

  .lede {
    max-width: 61ch;
    margin: 0 0 26px;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .hero-side {
    display: grid;
    gap: 16px;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .stat-grid article,
  .signal,
  .feature-card,
  .category-card {
    border: 1px solid var(--line);
    border-radius: 22px;
    background: var(--surface-strong);
  }

  .stat-grid article {
    padding: 18px;
  }

  .stat-grid strong {
    display: block;
    font-family: var(--serif);
    font-size: 2rem;
  }

  .stat-grid span,
  .signal,
  .section-note,
  .feature-meta,
  .category-card p,
  .utility-card p {
    color: var(--muted);
  }

  .signal {
    padding: 20px;
  }

  .signal-label {
    margin: 0 0 8px;
    color: var(--forest);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .split {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .section-head {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    margin-bottom: 22px;
  }

  .section-head h2 {
    font-size: clamp(2rem, 3vw, 3rem);
  }

  .feature-grid,
  .category-grid,
  .utility-grid {
    display: grid;
    gap: 16px;
  }

  .feature-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .feature-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 16px;
    align-items: start;
    padding: 20px;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .feature-card:hover,
  .category-card:hover,
  .utility-card:hover {
    transform: translateY(-3px);
    border-color: rgba(193, 99, 29, 0.32);
  }

  .index {
    font-family: var(--serif);
    font-size: 2rem;
    color: var(--accent);
  }

  .feature-meta,
  .count {
    font-size: 0.9rem;
  }

  .feature-card h3,
  .category-card h3 {
    margin: 6px 0 10px;
    font-size: 1.45rem;
  }

  .feature-card p,
  .category-card p {
    margin: 0;
  }

  .read-time {
    white-space: nowrap;
    color: var(--forest);
    font-weight: 600;
  }

  .category-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .category-card {
    padding: 22px;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .category-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .emoji {
    font-size: 1.45rem;
  }

  .utility-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .utility-card {
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .utility-card h2 {
    font-size: 1.5rem;
  }

  @media (max-width: 980px) {
    .hero-grid,
    .split,
    .feature-grid,
    .category-grid,
    .utility-grid,
    .section-head {
      grid-template-columns: 1fr;
    }

    h1 {
      max-width: 12ch;
    }
  }
</style>
