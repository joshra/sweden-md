---
import Layout from "../../layouts/Layout.astro";

const projects = [
  { title: "Sweden.md Frontend", description: "The main site, projecting `knowledge/` into an editorial reading interface." },
  { title: "Knowledge Graph", description: "A network view for understanding categories and articles through relationships." },
  { title: "Map View", description: "A spatial reading surface for landscapes, cities, and regional essays." }
];
---

<Layout title="Projects | Sweden.md" description="Project entry points for Sweden.md's frontend and knowledge display modules." lang="en">
  <section class="card">
    <div class="card-inner hero">
      <p class="eyebrow">Projects</p>
      <h1>Sweden.md is not just a site. It is a set of expandable knowledge interfaces.</h1>
    </div>
  </section>
  <section class="grid">
    {projects.map((project) => (
      <article class="card"><div class="card-inner"><h2>{project.title}</h2><p>{project.description}</p></div></article>
    ))}
  </section>
</Layout>

<style>
  .hero, .grid { display:grid; gap:18px; }
  h1 { font-size: clamp(2.6rem, 5vw, 4.6rem); margin:0; }
  .grid { grid-template-columns: repeat(3, minmax(0,1fr)); }
  .grid h2, .grid p { margin:0; }
  .grid h2 { margin-bottom:10px; }
  .grid p { color: var(--muted); }
  @media (max-width: 980px) { .grid { grid-template-columns:1fr; } }
</style>
