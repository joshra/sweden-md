---
import Layout from "../layouts/Layout.astro";
import KnowledgeGraph from "../components/KnowledgeGraph.astro";

const initialQuery = Astro.url.searchParams.get("q")?.trim() || "";
---

<Layout title="知識圖譜 | Sweden.md" description="探索 Sweden.md 文章之間的連結、分類群落與跨主題路徑。" lang="zh-TW" pageType="graph" accent="#588cb9" accentSoft="rgba(88, 140, 185, 0.16)">
  <KnowledgeGraph locale="zh-TW" initialQuery={initialQuery} />
</Layout>
