---
import Layout from "../layouts/Layout.astro";
import { getCategories, getFeaturedArticles, getSiteMetrics } from "../utils/content";

const categories = getCategories("zh-TW");
const primaryCategories = categories.filter((category) => !["about", "resources"].includes(category.slug));
const utilityCategories = categories.filter((category) => ["about", "resources"].includes(category.slug));
const featuredArticles = getFeaturedArticles("zh-TW");
const metrics = getSiteMetrics("zh-TW");
const quickLinks = [
  ...utilityCategories.map((category) => ({
    eyebrow: `${category.emoji} ${category.title}`,
    title: category.description,
    href: category.href
  })),
  { eyebrow: "✋ 貢獻", title: "想補內容、前端或資料入口，從這裡開始。", href: "/contribute" },
  { eyebrow: "🕒 更新", title: "追蹤最近新增與最近被擴寫的文章。", href: "/changelog" }
];
---

<Layout title="Sweden.md" description="用策展式前端入口理解瑞典的歷史、社會、文化與技術。 " lang="zh-TW">
  <section class="card hero">
    <div class="card-inner hero-grid">
      <div>
        <p class="eyebrow">Curated knowledge base for Sweden</p>
        <h1>不是把文章排上網，而是先替讀者鋪好進入瑞典的路徑。</h1>
        <p class="lede">
          參照 `taiwan.md` 的做法，Sweden.md 首頁應該先回答「從哪裡開始理解瑞典」，而不只是展示
          `knowledge/` 的存在。這裡把歷史、制度、文化與自然放進同一個可探索的入口。
        </p>
        <div class="button-row">
          <a class="button" href="#featured">從 5 篇開始</a>
          <a class="button secondary" href="#categories">瀏覽全部分類</a>
          <a class="button secondary" href="/graph">知識圖譜</a>
        </div>
      </div>

      <div class="hero-side">
        <div class="stat-grid">
          <article>
            <strong>{metrics.articleCount}+</strong>
            <span>主題文章</span>
          </article>
          <article>
            <strong>{metrics.categoryCount}</strong>
            <span>核心分類</span>
          </article>
          <article>
            <strong>雙語</strong>
            <span>中英對照架構</span>
          </article>
          <article>
            <strong>SSOT</strong>
            <span>`knowledge/` 為內容母本</span>
          </article>
        </div>

        <div class="signal">
          <p class="signal-label">為什麼這種入口有效</p>
          <p>
            `taiwan.md` 最值得學的地方，是它把首頁當成策展展場入口，而不是 README。讀者先感受到國家的輪廓，再決定深入哪一條線。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="split">
    <article class="card">
      <div class="card-inner">
        <p class="eyebrow">理解瑞典的三條線</p>
        <h2>先抓結構，再讀細節。</h2>
        <p>
          瑞典不是只有北歐設計或福利國。這個網站把閱讀動線拆成三個層次：先看制度與歷史如何塑造國家，再看日常文化如何把抽象價值落地，最後回到技術、自然與地方差異。
        </p>
      </div>
    </article>

    <article class="card">
      <div class="card-inner">
        <p class="eyebrow">前端優化目標</p>
        <h2>把內容網絡顯性化。</h2>
        <p>
          這一版首頁優先補上 `taiwan.md` 擅長的三件事：強 hero、清楚的起手閱讀清單、以及能快速橫向移動的分類入口。
        </p>
      </div>
    </article>
  </section>

  <section id="featured" class="card">
    <div class="card-inner">
      <div class="section-head">
        <div>
          <p class="eyebrow">Start here</p>
          <h2>不知道從哪開始，就先讀這 5 篇。</h2>
        </div>
        <p class="section-note">用 30 分鐘抓到瑞典最核心的幾條敘事線。</p>
      </div>

      <div class="feature-grid">
        {featuredArticles.map((article, index) => (
          <a class="feature-card" href={article.href}>
            <span class="index">{String(index + 1).padStart(2, "0")}</span>
            <div>
              <p class="feature-meta">{categories.find((category) => category.slug === article.category)?.title}</p>
              <h3>{article.title}</h3>
              <p>{article.description || article.excerpt}</p>
            </div>
            <span class="read-time">{article.readingMinutes} 分鐘</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="categories" class="card">
    <div class="card-inner">
      <div class="section-head">
        <div>
          <p class="eyebrow">Explore</p>
          <h2>從分類切入，而不是在文章海裡迷路。</h2>
        </div>
        <p class="section-note">每個分類都先給一個策展視角，再延伸到具體文章。</p>
      </div>

      <div class="category-grid">
        {primaryCategories.map((category) => (
          <a class="category-card" href={category.href}>
            <div class="category-top">
              <span class="emoji">{category.emoji}</span>
              <span class="count">{category.articleCount} 篇</span>
            </div>
            <h3>{category.title}</h3>
            <p>{category.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="utility-grid">
    {quickLinks.map((item) => (
      <a class="card utility-card" href={item.href}>
        <div class="card-inner">
          <p class="eyebrow">{item.eyebrow}</p>
          <h2>{item.title}</h2>
        </div>
      </a>
    ))}
  </section>
</Layout>

<style>
  .hero-grid,
  .split,
  .section-head,
  .utility-grid {
    display: grid;
    gap: 22px;
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1.5fr) minmax(320px, 0.9fr);
    align-items: start;
  }

  h1 {
    font-size: clamp(3rem, 6vw, 5.8rem);
    max-width: 10ch;
    margin-bottom: 18px;
  }

  .lede {
    max-width: 61ch;
    margin: 0 0 26px;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .hero-side {
    display: grid;
    gap: 16px;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .stat-grid article,
  .signal,
  .feature-card,
  .category-card {
    border: 1px solid var(--line);
    border-radius: 22px;
    background: var(--surface-strong);
  }

  .stat-grid article {
    padding: 18px;
  }

  .stat-grid strong {
    display: block;
    font-family: var(--serif);
    font-size: 2rem;
  }

  .stat-grid span,
  .signal,
  .section-note,
  .feature-meta,
  .category-card p,
  .utility-card p {
    color: var(--muted);
  }

  .signal {
    padding: 20px;
  }

  .signal-label {
    margin: 0 0 8px;
    color: var(--forest);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .split {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .section-head {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    margin-bottom: 22px;
  }

  .section-head h2 {
    font-size: clamp(2rem, 3vw, 3rem);
  }

  .feature-grid,
  .category-grid,
  .utility-grid {
    display: grid;
    gap: 16px;
  }

  .feature-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .feature-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 16px;
    align-items: start;
    padding: 20px;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .feature-card:hover,
  .category-card:hover,
  .utility-card:hover {
    transform: translateY(-3px);
    border-color: rgba(193, 99, 29, 0.32);
  }

  .index {
    font-family: var(--serif);
    font-size: 2rem;
    color: var(--accent);
  }

  .feature-meta,
  .count {
    font-size: 0.9rem;
  }

  .feature-card h3,
  .category-card h3 {
    margin: 6px 0 10px;
    font-size: 1.45rem;
  }

  .feature-card p,
  .category-card p {
    margin: 0;
  }

  .read-time {
    white-space: nowrap;
    color: var(--forest);
    font-weight: 600;
  }

  .category-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .category-card {
    padding: 22px;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .category-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .emoji {
    font-size: 1.45rem;
  }

  .utility-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .utility-card {
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .utility-card h2 {
    font-size: 1.5rem;
  }

  @media (max-width: 980px) {
    .hero-grid,
    .split,
    .feature-grid,
    .category-grid,
    .utility-grid,
    .section-head {
      grid-template-columns: 1fr;
    }

    h1 {
      max-width: 12ch;
    }
  }
</style>
