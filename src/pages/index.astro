---
import Layout from "../layouts/Layout.astro";
import { getAllArticles, getCategories, getFeaturedArticles, getLatestArticles, getSiteMetrics } from "../utils/content";
import { withBase } from "../utils/paths";

const categories = getCategories("zh-TW");
const primaryCategories = categories.filter((category) => !["about", "resources"].includes(category.slug));
const featuredArticles = getFeaturedArticles("zh-TW");
const latestArticles = getLatestArticles("zh-TW", 6);
const allArticles = getAllArticles("zh-TW").filter((article) => !article.isHub);
const metrics = getSiteMetrics("zh-TW");

const searchIndex = allArticles.map((article) => ({
  title: article.title,
  href: article.href,
  description: article.description || article.excerpt,
  category: categories.find((category) => category.slug === article.category)?.title || article.category,
  readingMinutes: article.readingMinutes
}));

const trendingTopics = [...primaryCategories].sort((a, b) => b.articleCount - a.articleCount).slice(0, 6);

const featuredSeries = [
  {
    eyebrow: "國家底圖",
    title: "先掌握歷史、制度與地理，才能讀懂今天的瑞典。",
    href: withBase("/history"),
    note: "從國家形成、福利國到區域差異，先建立理解瑞典的基本座標。"
  },
  {
    eyebrow: "日常文化",
    title: "從 fika、家庭節奏與季節儀式，看價值觀怎麼變成日常。",
    href: withBase("/culture"),
    note: "把抽象印象拆回生活現場，理解瑞典人如何工作、相處與過節。"
  },
  {
    eyebrow: "城市與產業",
    title: "從城市、科技到經濟結構，補上瑞典的現代運作方式。",
    href: withBase("/cities"),
    note: "看見首都之外的區域節點，也看見產業、人才與基礎建設如何流動。"
  }
];

const utilityLinks = [
  { eyebrow: "🗺️ 地圖", title: "用空間方式瀏覽分類與文章。", href: withBase("/map") },
  { eyebrow: "📚 資源", title: "查官方網站、統計資料與研究入口。", href: withBase("/resources") },
  { eyebrow: "ℹ️ 關於", title: "理解 Sweden.md 的編輯方向與內容方法。", href: withBase("/about") },
  { eyebrow: "🕒 更新", title: "追蹤最近新增與最近擴寫的文章。", href: withBase("/changelog") },
  { eyebrow: "✋ 貢獻", title: "想補內容、前端或資料入口，從這裡開始。", href: withBase("/contribute") }
];

const audienceUseCases = [
  "想快速建立對瑞典的整體理解，而不是只停留在北歐印象。",
  "需要可靠且可追溯的內容入口，拿來做研究、教學、寫作或產品背景整理。",
  "想從單一主題一路延伸到制度、城市、文化與產業脈絡。"
];
---

<Layout
  title="Sweden.md"
  description="用策展式前端入口理解瑞典的歷史、社會、文化與技術。"
  lang="zh-TW"
  pageType="home"
>
  <section class="card hero">
    <div class="card-inner hero-grid">
      <div>
        <p class="eyebrow">Sweden.md | 給台灣讀者的瑞典知識入口</p>
        <h1>用一個更完整的方式理解瑞典。</h1>
        <p class="lede">
          這裡不是旅遊清單，也不是零散百科。Sweden.md 以策展式結構整理瑞典的歷史、社會、文化、城市與技術，讓第一次進站的讀者能快速找到可信、可讀、也有脈絡的內容。
        </p>

        <div class="button-row">
          <a class="button" href="#featured">開始閱讀</a>
          <a class="button secondary" href="#search">站內搜尋</a>
          <a class="button secondary" href="#latest">最新更新</a>
        </div>

        <form id="search" class="search-panel" action={withBase("/graph")}>
          <label class="search-label" for="home-search">搜尋文章、分類、城市或關鍵主題</label>
          <input id="home-search" type="search" name="q" placeholder="例如：福利國、Fika、斯德哥爾摩、Spotify" autocomplete="off" />
          <div id="search-results" class="search-results" aria-live="polite">
            {searchIndex.slice(0, 6).map((article) => (
              <a class="search-result" href={article.href} data-search-item>
                <span class="search-meta">{article.category} · {article.readingMinutes} 分鐘</span>
                <strong>{article.title}</strong>
                <span>{article.description}</span>
              </a>
            ))}
          </div>
        </form>
      </div>

      <div class="hero-side">
        <div class="stat-grid">
          <article>
            <strong>{metrics.articleCount}+</strong>
            <span>篇主題文章</span>
          </article>
          <article>
            <strong>{metrics.categoryCount}</strong>
            <span>個核心分類</span>
          </article>
          <article>
            <strong>{featuredArticles.length}</strong>
            <span>篇起手精選</span>
          </article>
          <article>
            <strong>{latestArticles.length}</strong>
            <span>則近期更新</span>
          </article>
        </div>

        <div class="signal">
          <p class="signal-label">這裡適合誰</p>
          <ul class="audience-list">
            {audienceUseCases.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="trending" class="split">
    <article class="card">
      <div class="card-inner">
        <div class="section-head compact">
          <div>
            <p class="eyebrow">Trending topics</p>
            <h2>熱門主題</h2>
          </div>
          <p class="section-note">從目前內容最完整的區塊開始，先進入一條能持續延伸的閱讀路徑。</p>
        </div>

        <div class="topic-cluster">
          {trendingTopics.map((category) => (
            <a class="topic-chip" href={category.href}>
              <span>{category.emoji} {category.title}</span>
              <strong>{category.articleCount} 篇</strong>
            </a>
          ))}
        </div>
      </div>
    </article>

    <article class="card">
      <div class="card-inner">
        <div class="section-head compact">
          <div>
            <p class="eyebrow">Series</p>
            <h2>系列入口</h2>
          </div>
          <p class="section-note">如果你不確定從哪裡開始，先沿著一條清楚的敘事線進站。</p>
        </div>

        <div class="series-list">
          {featuredSeries.map((series) => (
            <a class="series-card" href={series.href}>
              <p class="eyebrow">{series.eyebrow}</p>
              <h3>{series.title}</h3>
              <p>{series.note}</p>
            </a>
          ))}
        </div>
      </div>
    </article>
  </section>

  <section id="featured" class="card">
    <div class="card-inner">
      <div class="section-head">
        <div>
          <p class="eyebrow">Editor's picks</p>
          <h2>編輯精選</h2>
        </div>
        <p class="section-note">這五篇不是隨機抽樣，而是幫第一次進站的讀者先排好的理解順序。</p>
      </div>

      <div class="feature-grid">
        {featuredArticles.map((article, index) => (
          <a class="feature-card" href={article.href}>
            <span class="index">{String(index + 1).padStart(2, "0")}</span>
            <div>
              <p class="feature-meta">{categories.find((category) => category.slug === article.category)?.title}</p>
              <h3>{article.title}</h3>
              <p>{article.description || article.excerpt}</p>
            </div>
            <span class="read-time">{article.readingMinutes} 分鐘</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="latest" class="card">
    <div class="card-inner">
      <div class="section-head">
        <div>
          <p class="eyebrow">Latest</p>
          <h2>最新整理</h2>
        </div>
        <p class="section-note">追蹤最近新增與擴寫的內容，快速掌握這個知識庫近期補強了哪些主題。</p>
      </div>

      <div class="latest-grid">
        {latestArticles.map((article) => (
          <a class="latest-card" href={article.href}>
            <span class="latest-category">{categories.find((category) => category.slug === article.category)?.title}</span>
            <h3>{article.title}</h3>
            <p>{article.description || article.excerpt}</p>
            <span class="latest-meta">{article.updatedAt.toLocaleDateString("zh-TW")} · {article.readingMinutes} 分鐘</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="categories" class="card">
    <div class="card-inner">
      <div class="section-head">
        <div>
          <p class="eyebrow">Explore</p>
          <h2>全部主題入口</h2>
        </div>
        <p class="section-note">完整分類仍然保留，方便你按主題建立自己的閱讀地圖。</p>
      </div>

      <div class="category-grid">
        {primaryCategories.map((category) => (
          <a class="category-card" href={category.href}>
            <div class="category-top">
              <span class="emoji">{category.emoji}</span>
              <span class="count">{category.articleCount} 篇</span>
            </div>
            <h3>{category.title}</h3>
            <p>{category.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="toolbox">
    <div class="section-head compact">
      <div>
        <p class="eyebrow">Tools and site</p>
        <h2>工具與站務</h2>
      </div>
      <p class="section-note">當你要查資料來源、理解站點方法，或用不同介面瀏覽內容時，再從這裡往下走。</p>
    </div>

    <div class="utility-grid">
      {utilityLinks.map((item) => (
        <a class="card utility-card" href={item.href}>
          <div class="card-inner">
            <p class="eyebrow">{item.eyebrow}</p>
            <h3>{item.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<script define:vars={{ searchIndex }}>
  const input = document.getElementById("home-search");
  const results = document.getElementById("search-results");

  if (input instanceof HTMLInputElement && results instanceof HTMLElement) {
    const renderResults = (items) => {
      results.innerHTML = items
        .map(
          (article) => `
            <a class="search-result" href="${article.href}">
              <span class="search-meta">${article.category} · ${article.readingMinutes} 分鐘</span>
              <strong>${article.title}</strong>
              <span>${article.description}</span>
            </a>
          `
        )
        .join("");
    };

    const defaultResults = searchIndex.slice(0, 6);
    renderResults(defaultResults);

    input.addEventListener("input", () => {
      const query = input.value.trim().toLowerCase();

      if (!query) {
        renderResults(defaultResults);
        return;
      }

      const filtered = searchIndex
        .filter((article) =>
          [article.title, article.description, article.category].some((field) =>
            field.toLowerCase().includes(query)
          )
        )
        .slice(0, 6);

      renderResults(
        filtered.length
          ? filtered
          : [
              {
                href: `${withBase("/graph")}?q=${encodeURIComponent(query)}`,
                category: "繼續搜尋",
                title: `找不到精準結果，改到知識圖譜搜尋「${query}」`,
                description: "前往圖譜頁查看完整文章與分類網絡。",
                readingMinutes: "圖譜"
              }
            ]
      );
    });
  }
</script>

<style>
  .hero-grid,
  .split,
  .section-head,
  .utility-grid,
  .latest-grid {
    display: grid;
    gap: 22px;
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.85fr);
    align-items: start;
  }

  h1 {
    font-size: clamp(3rem, 6vw, 5.6rem);
    max-width: 10ch;
    margin-bottom: 18px;
  }

  .lede {
    max-width: 61ch;
    margin: 0 0 26px;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .hero-side,
  .series-list,
  .toolbox {
    display: grid;
    gap: 16px;
  }

  .search-panel,
  .signal,
  .stat-grid article,
  .feature-card,
  .category-card,
  .latest-card,
  .series-card,
  .topic-chip,
  .search-result {
    border: 1px solid var(--line);
    border-radius: 22px;
    background: var(--surface-strong);
  }

  .search-panel {
    display: grid;
    gap: 12px;
    margin-top: 24px;
    padding: 18px;
  }

  .search-label,
  .signal-label,
  .search-meta,
  .latest-category,
  .latest-meta,
  .feature-meta,
  .count,
  .section-note,
  .category-card p,
  .series-card p,
  .utility-card p {
    color: var(--muted);
  }

  .search-label,
  .signal-label,
  .latest-category {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  #home-search {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.65);
    color: var(--ink);
    font: inherit;
  }

  #home-search:focus {
    outline: 2px solid rgba(193, 99, 29, 0.24);
    outline-offset: 2px;
  }

  .search-results {
    display: grid;
    gap: 10px;
  }

  .audience-list {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 10px;
    color: var(--muted);
  }

  .search-result {
    display: grid;
    gap: 4px;
    padding: 14px 16px;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .search-result:hover,
  .search-result:focus-visible,
  .feature-card:hover,
  .feature-card:focus-visible,
  .category-card:hover,
  .category-card:focus-visible,
  .latest-card:hover,
  .latest-card:focus-visible,
  .series-card:hover,
  .series-card:focus-visible,
  .topic-chip:hover,
  .topic-chip:focus-visible,
  .utility-card:hover,
  .utility-card:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(193, 99, 29, 0.28);
  }

  .hero-side {
    gap: 18px;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .stat-grid article,
  .signal {
    padding: 18px;
  }

  .stat-grid strong {
    display: block;
    font-family: var(--serif);
    font-size: 2rem;
  }

  .split {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .section-head {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    margin-bottom: 22px;
  }

  .section-head.compact {
    margin-bottom: 18px;
  }

  .section-head h2 {
    font-size: clamp(2rem, 3vw, 3rem);
  }

  .topic-cluster,
  .feature-grid,
  .category-grid,
  .utility-grid,
  .latest-grid {
    display: grid;
    gap: 16px;
  }

  .topic-cluster {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .topic-chip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 18px;
    text-decoration: none;
  }

  .topic-chip strong {
    font-family: var(--serif);
    font-size: 1.15rem;
  }

  .series-card,
  .latest-card,
  .category-card,
  .feature-card {
    text-decoration: none;
  }

  .series-card,
  .latest-card {
    display: grid;
    gap: 8px;
    padding: 20px;
  }

  .feature-grid,
  .latest-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .feature-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 18px;
    padding: 20px;
  }

  .index {
    font-family: var(--serif);
    font-size: 2rem;
    color: var(--accent);
    line-height: 1;
  }

  .read-time {
    align-self: start;
    color: var(--forest);
    font-size: 0.88rem;
    font-weight: 600;
  }

  .category-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .category-card {
    display: grid;
    gap: 12px;
    padding: 20px;
  }

  .category-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .emoji {
    font-size: 1.45rem;
  }

  .utility-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .utility-card {
    text-decoration: none;
  }

  @media (max-width: 980px) {
    .hero-grid,
    .split,
    .feature-grid,
    .category-grid,
    .utility-grid,
    .latest-grid,
    .section-head,
    .topic-cluster {
      grid-template-columns: 1fr;
    }

    h1 {
      max-width: 12ch;
    }
  }
</style>
