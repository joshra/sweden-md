---
import Layout from "../layouts/Layout.astro";
import { getAllArticles, getCategories, getFeaturedArticles, getLatestArticles, getSiteMetrics } from "../utils/content";
import { withBase } from "../utils/paths";

const categories = getCategories("zh-TW");
const primaryCategories = categories.filter((category) => !["about", "resources"].includes(category.slug));
const featuredArticles = getFeaturedArticles("zh-TW");
const latestArticles = getLatestArticles("zh-TW", 4);
const allArticles = getAllArticles("zh-TW").filter((article) => !article.isHub);
const metrics = getSiteMetrics("zh-TW");
const prioritizedCategorySlugs = ["culture", "food", "lifestyle", "history"];

const searchIndex = allArticles.map((article) => ({
  title: article.title,
  href: article.href,
  description: article.description || article.excerpt,
  category: categories.find((category) => category.slug === article.category)?.title || article.category,
  readingMinutes: article.readingMinutes
}));

const readingPaths = [
  {
    title: "文化入口",
    text: "先從 Fika、家常餐桌、季節儀式與設計感進站，會比先背制度名詞更快摸到瑞典日常的質地。"
  },
  {
    title: "生活節奏",
    text: "把工作邊界、育兒假、家居想像與公共美學一起讀，才能理解瑞典如何安排時間、關係與私人空間。"
  },
  {
    title: "制度與轉型",
    text: "文化讀進去之後，再回頭看歷史、福利國、科技與城市結構，瑞典就不會只剩下北歐標籤。"
  }
];

const homeTopics = [
  ...featuredArticles.slice(0, 5),
  ...[
    ...primaryCategories.filter((category) => prioritizedCategorySlugs.includes(category.slug)),
    ...primaryCategories.filter((category) => !prioritizedCategorySlugs.includes(category.slug))
  ]
    .filter((category) => !featuredArticles.some((article) => article.category === category.slug))
    .slice(0, 4)
    .map((category) => ({
      href: category.href,
      title: category.title,
      description: category.description,
      category: category.title,
      readingMinutes: category.articleCount,
      isCategory: true
    }))
];

const utilityLinks = [
  { title: "搜尋知識圖譜", href: withBase("/graph"), note: "用關聯方式找文章與分類。" },
  { title: "地圖模式", href: withBase("/map"), note: "從地理與空間關係進站。" },
  { title: "資料與來源", href: withBase("/resources"), note: "官方網站、統計與研究入口。" },
  { title: "關於 Sweden.md", href: withBase("/about"), note: "編輯方向、寫作方法與標準。" }
];
---

<Layout
  title="Sweden.md"
  description="給台灣讀者的瑞典策展式知識入口，先讀懂國家，再走進城市、制度、文化與科技。"
  lang="zh-TW"
  pageType="home"
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Sweden.md</p>
      <h1>把瑞典讀得更近一點，也更舒服一點。</h1>
      <p class="lead">
        給想真正認識瑞典的讀者，一個不急著塞滿資訊、而是能慢慢讀進去的入口。你會先遇見 `Fika`、餐桌、季節儀式與生活節奏，再自然走到城市、制度、歷史與當代轉型，讓理解不是硬記，而是一步一步變清楚。
      </p>

      <div class="hero-metrics">
        <article>
          <strong>{metrics.articleCount}+</strong>
          <span>主題文章</span>
        </article>
        <article>
          <strong>{metrics.categoryCount}</strong>
          <span>核心分類</span>
        </article>
        <article>
          <strong>{featuredArticles.length}</strong>
          <span>入門起點</span>
        </article>
      </div>
    </div>

    <aside class="hero-panel">
      <p class="eyebrow">From Taiwan to Sweden</p>
      <h2>讀者會在這裡得到什麼</h2>
      <p>
        不是一張冷冷的分類表，也不是一套要你先學會規則才能使用的資訊系統。這裡比較像一張閱讀沙發，幫你把瑞典放進有節奏、有畫面的文章裡，讀起來輕鬆，但內容不輕。
      </p>
      <ul>
        <li>先從好入口開始，不會一上來就被制度名詞淹沒。</li>
        <li>用文章的節奏帶你理解，而不是用功能表逼你做功課。</li>
        <li>保留深度與來源，但把閱讀感放在第一位。</li>
      </ul>
      <div class="north-star">
        <span>N</span>
        <span>S</span>
        <span>森林、能源與資源腹地</span>
        <span>人口、城市與制度核心</span>
      </div>
    </aside>
  </section>

  <section class="section-heading">
    <p class="eyebrow">Reading Path</p>
    <h2>先讀文化與日常，再往制度、城市與國家尺度擴張。</h2>
  </section>

  <section class="feature-grid">
    {readingPaths.map((item) => (
      <article>
        <h2>{item.title}</h2>
        <p>{item.text}</p>
      </article>
    ))}
  </section>

  <section class="section-heading">
    <p class="eyebrow">Starter Topics</p>
    <h2>首頁先把文化主題推到前面，因為這才是最自然的瑞典入口。</h2>
  </section>

  <section class="topic-grid">
    {homeTopics.map((item, index) => (
      <article class="topic-card">
        <p class="topic-number">{item.isCategory ? "Category" : `Start ${index + 1}`}</p>
        <h2><a href={item.href}>{item.title}</a></h2>
        <p>{item.description}</p>
        <div class="pill-row">
          <span class="pill">{item.isCategory ? item.category : categories.find((category) => category.slug === item.category)?.title}</span>
          <span class="pill">{item.isCategory ? `${item.readingMinutes} 篇` : `${item.readingMinutes} 分鐘`}</span>
        </div>
      </article>
    ))}
  </section>

  <section class="section-heading split-heading">
    <div>
      <p class="eyebrow">Recent Updates</p>
      <h2>最近新增與擴寫</h2>
    </div>
    <a class="inline-link" href={withBase("/changelog")}>看全部更新 →</a>
  </section>

  <section class="latest-grid">
    {latestArticles.map((article) => (
      <article class="latest-card">
        <p class="topic-number">Latest</p>
        <h2><a href={article.href}>{article.title}</a></h2>
        <p>{article.description || article.excerpt}</p>
        <div class="pill-row">
          <span class="pill">{categories.find((category) => category.slug === article.category)?.title}</span>
          <span class="pill">{article.updatedAt.toLocaleDateString("zh-TW")}</span>
        </div>
      </article>
    ))}
  </section>

  <section class="utility-strip">
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">Tools</p>
        <h2>搜尋與站務入口</h2>
      </div>
    </div>

    <div class="utility-grid">
      {utilityLinks.map((item) => (
        <a class="utility-card" href={item.href}>
          <h3>{item.title}</h3>
          <p>{item.note}</p>
        </a>
      ))}
    </div>

    <form id="search" class="search-panel" action={withBase("/graph")}>
      <label class="eyebrow" for="home-search">Search</label>
      <input id="home-search" type="search" name="q" placeholder="例如：福利國、哥德堡、Fika、Spotify" autocomplete="off" />
      <div id="search-results" class="search-results" aria-live="polite">
        {searchIndex.slice(0, 6).map((article) => (
          <a class="search-result" href={article.href}>
            <strong>{article.title}</strong>
            <span>{article.category} · {article.readingMinutes} 分鐘 · {article.description}</span>
          </a>
        ))}
      </div>
    </form>
  </section>
</Layout>

<script define:vars={{ searchIndex }}>
  const input = document.getElementById("home-search");
  const results = document.getElementById("search-results");

  if (input instanceof HTMLInputElement && results instanceof HTMLElement) {
    const renderResults = (items) => {
      results.innerHTML = items
        .map(
          (article) => `
            <a class="search-result" href="${article.href}">
              <strong>${article.title}</strong>
              <span>${article.category} · ${article.readingMinutes} 分鐘 · ${article.description}</span>
            </a>
          `
        )
        .join("");
    };

    const defaultResults = searchIndex.slice(0, 6);
    renderResults(defaultResults);

    input.addEventListener("input", () => {
      const query = input.value.trim().toLowerCase();
      if (!query) {
        renderResults(defaultResults);
        return;
      }

      const filtered = searchIndex
        .filter((article) =>
          [article.title, article.description, article.category].some((field) =>
            field.toLowerCase().includes(query)
          )
        )
        .slice(0, 6);

      renderResults(
        filtered.length
          ? filtered
          : [
              {
                href: `${withBase("/graph")}?q=${encodeURIComponent(query)}`,
                title: `改到圖譜搜尋「${query}」`,
                category: "繼續搜尋",
                readingMinutes: "圖譜",
                description: "前往完整文章與分類網絡。"
              }
            ]
      );
    });
  }
</script>

<style>
  .hero,
  .feature-grid,
  .topic-grid,
  .latest-grid,
  .utility-grid {
    display: grid;
    gap: 20px;
  }

  .hero,
  .feature-grid article,
  .topic-card,
  .latest-card,
  .utility-card,
  .search-panel {
    backdrop-filter: blur(12px);
    background: rgba(255, 251, 244, 0.9);
    border: 1px solid rgba(25, 33, 38, 0.12);
    box-shadow: 0 24px 60px rgba(25, 33, 38, 0.1);
  }

  .hero {
    grid-template-columns: 1.3fr 0.9fr;
    gap: 24px;
    padding: 32px;
    border-radius: 32px;
    position: relative;
    overflow: hidden;
  }

  .hero::after {
    content: "";
    position: absolute;
    width: 340px;
    height: 340px;
    right: -60px;
    top: -80px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(15, 118, 110, 0.18), transparent 68%);
  }

  .hero h1 {
    font-size: clamp(3rem, 5vw, 5.2rem);
    line-height: 1.05;
    margin: 0 0 14px;
    max-width: 10ch;
  }

  .eyebrow,
  .topic-number {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    color: #0f766e;
    margin: 0 0 10px;
  }

  .topic-number {
    display: inline-block;
    padding: 4px 8px;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.1);
  }

  .lead,
  .hero-panel p,
  .hero-panel li,
  .feature-grid p,
  .topic-card p,
  .latest-card p,
  .utility-card p,
  .search-result span {
    color: var(--muted);
  }

  .lead {
    max-width: 60ch;
    font-size: 1.08rem;
  }

  .hero-panel,
  .search-panel {
    padding: 22px;
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(15, 118, 110, 0.12), rgba(217, 119, 6, 0.06)),
      linear-gradient(135deg, rgba(255, 255, 255, 0.55), rgba(255, 255, 255, 0.2));
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 24px;
    max-width: 640px;
  }

  .hero-metrics article {
    padding: 14px 16px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(25, 33, 38, 0.08);
  }

  .hero-metrics strong {
    display: block;
    font-size: 1.6rem;
    color: #0f766e;
  }

  .north-star {
    margin-top: 18px;
    display: grid;
    grid-template-columns: 32px 32px 1fr 1fr;
    gap: 10px;
    align-items: center;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .north-star span:nth-child(1),
  .north-star span:nth-child(2) {
    display: inline-grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(25, 33, 38, 0.12);
    color: #0f766e;
    background: rgba(255, 255, 255, 0.65);
  }

  .section-heading {
    margin-top: 10px;
    padding-inline: 4px;
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.5rem, 2vw, 2.2rem);
    max-width: 20ch;
  }

  .split-heading {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: end;
  }

  .feature-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .feature-grid article,
  .topic-card,
  .latest-card,
  .utility-card {
    padding: 24px;
    border-radius: 24px;
    position: relative;
    overflow: hidden;
  }

  .feature-grid article::after,
  .topic-card::after,
  .latest-card::after {
    content: "";
    position: absolute;
    inset: auto -24px -40px auto;
    width: 110px;
    height: 110px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(15, 118, 110, 0.12), transparent 70%);
  }

  .topic-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .latest-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .utility-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-bottom: 20px;
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.08);
    color: #0f766e;
    font-size: 0.88rem;
  }

  .inline-link,
  .topic-card a,
  .latest-card a,
  .utility-card {
    text-decoration: none;
  }

  .search-panel input {
    width: 100%;
    padding: 14px 16px;
    border-radius: 14px;
    border: 1px solid rgba(25, 33, 38, 0.12);
    background: rgba(255, 255, 255, 0.7);
    color: var(--ink);
    font: inherit;
  }

  .search-results {
    display: grid;
    gap: 10px;
    margin-top: 14px;
  }

  .search-result {
    display: grid;
    gap: 4px;
    padding: 12px 14px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(25, 33, 38, 0.08);
    text-decoration: none;
  }

  @media (max-width: 1100px) {
    .hero,
    .feature-grid,
    .topic-grid,
    .latest-grid,
    .utility-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .split-heading {
      display: grid;
    }
  }

  @media (max-width: 780px) {
    .hero,
    .feature-grid,
    .topic-grid,
    .latest-grid,
    .utility-grid,
    .hero-metrics {
      grid-template-columns: 1fr;
    }

    .north-star {
      grid-template-columns: 32px 32px 1fr;
    }

    .hero {
      padding: 24px;
    }
  }
</style>
