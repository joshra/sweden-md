---
import Layout from "../layouts/Layout.astro";

const projects = [
  { title: "Sweden.md Frontend", description: "網站本體，負責把 `knowledge/` 投影成策展式閱讀介面。" },
  { title: "Knowledge Graph", description: "把分類與文章節點視覺化，讓讀者用網絡而非清單理解內容。" },
  { title: "Map View", description: "把地景與城市文章放回空間中閱讀。" }
];
---

<Layout title="Projects | Sweden.md" description="Sweden.md 前端與知識展示模組的專案入口。" lang="zh-TW">
  <section class="card">
    <div class="card-inner hero">
      <p class="eyebrow">Projects</p>
      <h1>Sweden.md 不只是一個網站，也是一組可持續擴張的知識介面。</h1>
    </div>
  </section>
  <section class="grid">
    {projects.map((project) => (
      <article class="card"><div class="card-inner"><h2>{project.title}</h2><p>{project.description}</p></div></article>
    ))}
  </section>
</Layout>

<style>
  .hero, .grid { display:grid; gap:18px; }
  h1 { font-size: clamp(2.6rem, 5vw, 4.6rem); margin:0; }
  .grid { grid-template-columns: repeat(3, minmax(0,1fr)); }
  .grid h2, .grid p { margin:0; }
  .grid h2 { margin-bottom:10px; }
  .grid p { color: var(--muted); }
  @media (max-width: 980px) { .grid { grid-template-columns:1fr; } }
</style>
